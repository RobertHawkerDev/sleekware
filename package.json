{
  "name": "sleekware",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "graphql-codegen && next build",
    "codegen": "graphql-codegen",
    "codegen:watch": "graphql-codegen --watch",
    "commit": "cz",
    "dev": "graphql-codegen || true && next dev",
    "dev:portless": "graphql-codegen || true && portless shop next dev",
    "format": "oxfmt",
    "lint": "oxlint . && oxfmt --check",
    "typecheck": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@ai-sdk/react": "4.0.16",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@shopify/storefront-api-client": "1.0.10",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "7.0.15",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.23.0",
    "nanoid": "5.1.16",
    "next": "16.3.0-canary.72",
    "next-intl": "4.13.1",
    "radix-ui": "1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "use-stick-to-bottom": "1.1.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@graphql-codegen/cli": "^7.1.3",
    "@shopify/api-codegen-preset": "^2.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "postcss": "^8.5.16",
    "typescript": "^6.0.3"
  }
